# ArangoDB Connection (required)
ARANGO_HOSTS=http://localhost:8529
ARANGO_ROOT_USERNAME=root
ARANGO_ROOT_PASSWORD=          # <-- set your password here

# ArangoDB Options (optional)
ARANGO_DEFAULT_DB_NAME=_system
ARANGO_VERIFY_SSL=true
ARANGO_SSL_CERT_PATH=

# MCP Server (optional)
SERVER_NAME=ArangoDB MCP Server
SERVER_VERSION=2.0.0
LOG_LEVEL=INFO
LOG_FORMAT=text                # text | json   (json = one-line JSON per record, for log aggregation)
MCP_TRANSPORT=stdio            # stdio | sse | streamable-http
MCP_HOST=0.0.0.0
MCP_PORT=8000

# Feature Flags
ENABLE_JS_TRANSACTIONS=false   # WARNING: allows arbitrary JS on the DB server

# AQL safety
DEFAULT_AQL_MAX_RUNTIME=30     # seconds; 0 = no limit. Per-call override available.
LOG_AQL_QUERIES=false          # true logs first 100 chars of user-supplied AQL (may contain literals)

# Connection resilience
CONNECT_MAX_RETRIES=5          # 0 disables retries
CONNECT_INITIAL_BACKOFF=1.0    # seconds; doubled per attempt, capped at 30s

# HTTP transport auth (sse / streamable-http)
# REQUIRED when MCP_HOST is non-loopback. Clients must send 'Authorization: Bearer <token>'.
MCP_AUTH_TOKEN=
